{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CyberChef",
  "version": "0.1.0",
  "identifier": "com.gchq.cyberchef.portable",
  "build": {
    "frontendDist": "../cyberchef-dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "CyberChef",
        "width": 1280,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "signingIdentity": "-"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": false
  }
}
